#!/bin/zsh
# decant — extract the main editable macOS .icon bundle from an app.
#
# This simplified entry point intentionally does one thing:
#   input:  a macOS .app bundle or an Assets.car file
#   output: ~/Downloads/<App Name>.icon
#
# It always uses the raw-SVG overlay pass. The normal CoreUI extraction preserves
# the icon layer tree, effects, and metadata; the overlay pass replaces any lossy
# CoreSVG re-exported SVGs with the original SVG bytes stored in the rendition
# when those bytes are available.

set -euo pipefail

HERE="${0:A:h}"
OVERLAY="$HERE/decant-rawsvg-overlay.zsh"

usage() {
  cat >&2 <<'EOF'
usage: ./decant /path/to/App.app
   or: ./decant /path/to/Assets.car

Output is written directly to:
  ~/Downloads/<App Name>.icon
EOF
  exit 2
}

die() {
  print -u2 "error: $*"
  exit 1
}

# Keep old Shortcuts commands from doing the wrong thing silently.
if [[ $# -ne 1 ]]; then
  usage
fi

INPUT="$1"
[[ -e "$INPUT" ]] || die "not found: $INPUT"
[[ -x "$OVERLAY" ]] || die "missing helper: $OVERLAY"

CAR=""
APP_NAME=""
BUNDLE_ICON_NAME=""

if [[ "$INPUT" == *.app ]]; then
  CAR="$INPUT/Contents/Resources/Assets.car"
  APP_NAME="${INPUT:t:r}"

  if [[ -f "$INPUT/Contents/Info.plist" ]]; then
    BUNDLE_ICON_NAME=$(/usr/libexec/PlistBuddy -c 'Print :CFBundleIconName' "$INPUT/Contents/Info.plist" 2>/dev/null || true)
  fi
else
  CAR="$INPUT"
  APP_NAME="${INPUT:t:r}"
fi

[[ -f "$CAR" ]] || die "Assets.car not found: $CAR"

# Pick the main IconImageStack automatically. Preference order:
#   1. CFBundleIconName from the app Info.plist, if present
#   2. common Apple defaults such as AppIcon
#   3. the only IconImageStack in the catalog
#   4. the first IconImageStack reported by assetutil
ASSETUTIL_JSON=$(mktemp "${TMPDIR:-/tmp}/decant-assetutil.XXXXXX.json")
trap 'rm -f "$ASSETUTIL_JSON"' EXIT

xcrun assetutil --info "$CAR" > "$ASSETUTIL_JSON"

STACK=$(python3 - "$BUNDLE_ICON_NAME" "$ASSETUTIL_JSON" <<'PY'
import json
import sys
from pathlib import Path

preferred = sys.argv[1] if len(sys.argv) > 1 else ""
json_path = Path(sys.argv[2])

try:
    items = json.loads(json_path.read_text(encoding="utf-8"))
except Exception as exc:
    raise SystemExit(f"could not read assetutil JSON: {exc}")

stacks = []
for item in items:
    if item.get("AssetType") == "IconImageStack":
        name = item.get("Name")
        if name and name not in stacks:
            stacks.append(name)

if not stacks:
    raise SystemExit("no IconImageStack found in Assets.car")

for candidate in [preferred, "AppIcon", "AppIconUpdated", "Settings"]:
    if candidate and candidate in stacks:
        print(candidate)
        raise SystemExit(0)

print(stacks[0])
PY
) || die "could not determine main icon stack"

OUT_ICON="$HOME/Downloads/$APP_NAME.icon"

print "App:   $APP_NAME"
print "Stack: $STACK"
print "Out:   $OUT_ICON"

zsh "$OVERLAY" "$CAR" "$STACK" "$OUT_ICON"

print "done -> $OUT_ICON"
